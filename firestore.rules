rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'phone', 'upiId', 'balance', 'emoji'])
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.phone is string && data.phone.size() <= 20
          && data.upiId is string && data.upiId.size() <= 50
          && data.balance is number
          && data.emoji is string && data.emoji.size() <= 10;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'senderName', 'receiverName', 'amount', 'timestamp'])
          && data.senderId is string && data.receiverId is string
          && data.senderName is string && data.receiverName is string
          && data.amount is number && data.amount > 0
          && data.timestamp == request.time;
    }

    match /users/{userId} {
      // Allows global UPI search
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn();
      
      // Enforce rigorous new user scheme with startup balance
      allow create: if isSignedIn() && request.auth.uid == userId
                    && isValidUser(incoming())
                    && incoming().balance == 10000;
                    
      // Balance updates only allowed when changing balance explicitly via isolated atomic transaction batches
      allow update: if isSignedIn()
                    && isValidUser(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['balance']);
    }
    
    match /transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      
      // Strict constraints locking transaction schema layout
      allow create: if isSignedIn() 
                    && incoming().senderId == request.auth.uid
                    && isValidTransaction(incoming());
    }
  }
}
